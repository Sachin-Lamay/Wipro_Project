# ============================================================
# Environment Variables Template
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── Snowflake ─────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account.snowflakecomputing.com
SNOWFLAKE_USER=SVC_ETL_USER
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ROLE=ECOMM_ETL_ROLE
SNOWFLAKE_WAREHOUSE=ECOMM_ETL_WH
SNOWFLAKE_DATABASE=ECOMM_DW
SNOWFLAKE_SCHEMA=STAGE

# ── PostgreSQL OLTP ───────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecomm_oltp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# ── AWS / S3 ──────────────────────────────────────────────────
S3_BUCKET=ecomm-data-lake
S3_PREFIX=raw/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ── Kafka (Streaming) ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=ecomm.events

# ── Spark ─────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_LOG_LEVEL=WARN
SPARK_SHUFFLE_PARTITIONS=200

# ── ETL Configuration ─────────────────────────────────────────
ETL_LOOKBACK_HOURS=24
ETL_CHUNK_SIZE=10000
ETL_WATERMARK_PATH=/tmp/etl_watermarks.json
